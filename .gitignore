# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Dependency managers (not used; ignored if ever added)
Pods/
Carthage/Build/

# Local media assets (break videos & audio) are NOT committed — typical stock licenses
# restrict redistributing the raw files. The app falls back to a gradient / silence when
# they're absent (see the "Assets" section of the README). Truly CC0 / public-domain files
# may be committed via explicit exceptions below.
Horizon/Horizon/BreakVideos/
Horizon/Horizon/BreakAudio/

# Build artifacts from scripts/package.sh
*.dmg

# Design reference mockups (not part of the app)
*.html
# ...but DO track the DMG install guide — package.sh bundles it inside the .dmg
!scripts/dmg/open-me-first.html

# Misc
*.log
